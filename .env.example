# ── Server ───────────────────────────────────────────────────────────────────
# Railway define $PORT automaticamente — não é necessário setar.
# PORT=8080

# ── Mode ─────────────────────────────────────────────────────────────────────
# Modo simples: define CLAUDE_SESSION_KEYS para rodar sem PostgreSQL/Redis.
# Separe múltiplas chaves com vírgula.
# Obtenha em: claude.ai → F12 → Application → Cookies → sessionKey
# CLAUDE_SESSION_KEYS=sk-ant-sid01-xxx,sk-ant-sid01-yyy

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# No Railway: adicione o plugin PostgreSQL — DATABASE_URL será injetada sozinha.
# Se preferir variáveis separadas, use as referências abaixo:
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_USER=${{Postgres.PGUSER}}
# DB_PASS=${{Postgres.PGPASSWORD}}
# DB_NAME=${{Postgres.PGDATABASE}}
# DB_SSLMODE=require

# Para Docker local (docker-compose), use os valores abaixo:
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=claude2api
# DB_PASS=change_me_please
# DB_NAME=claude2api

# ── Redis ─────────────────────────────────────────────────────────────────────
# No Railway: adicione o plugin Redis — REDIS_URL será injetada sozinha.
# Para Docker local, use os valores abaixo:
# REDIS_PASS=redis_secret
# REDIS_URL=redis://:redis_secret@redis:6379/0

# ── Residential Proxy (leave empty to connect directly) ───────────────────────
PROXY_HOST=
PROXY_PORT=3010
PROXY_USER=
PROXY_PASS=
PROXY_REGION=US

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Acesso em: https://seu-app.railway.app/admin
ADMIN_USER=admin
ADMIN_PASS=change_me_please     # ← OBRIGATÓRIO: troque antes de ir ao ar

# ── Rate Limiting ─────────────────────────────────────────────────────────────
CLAUDE_DAILY_LIMIT=0    # 0 = ilimitado
MAX_RETRIES=3
COOLDOWN_MINUTES=5

# ── API Key Protection ────────────────────────────────────────────────────────
# Sem esta variável, /v1/messages fica aberto sem autenticação.
# Defina para exigir: Authorization: Bearer SUA_CHAVE
# CLAUDE_API_KEY=sk-your-api-key
